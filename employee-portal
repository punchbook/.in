  <div class="toast" id="toast"></div>

  <script>
    // ============================================================
    // ⚠️ SIRF YEH LINE BADLO - APNI APPS SCRIPT URL YAHAN DAALO
    // ============================================================
    const API_URL = 'https://script.google.com/macros/s/AKfycbxPxRUqdubBd2xkGH1vSMq7tDzN1Zg_ABdY88etLy0f1KMKwCmas7to_XbI7WrpwHsk/exec'; 
    // ============================================================
    
    const MODEL_URL = 'https://cdn.jsdelivr.net/npm/@vladmandic/face-api@1.7.13/model';

    let currentEmployee = null;
    
    // Login Camera Vars
    let loginStream = null;
    let faceApiLoaded = false;
    let loginDetectionInterval = null;
    let loginFaceDetected = false;
    let loginCaptureInProgress = false;

    // Face Auth Data
    let allFaceDescriptors = [];
    let faceDataLoaded = false;
    
    // Settings Camera Vars
    let settingsFaceDescriptor = null;
    let settingsPhotoBase64 = null;
    let settingsStream = null;
    let settingsDetectionInterval = null;

    async function apiCall(params) {
      try {
        let response;
        if (params.action === 'changePassword' || params.action === 'saveFaceData') {
          response = await fetch(API_URL, {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: new URLSearchParams(params).toString()
          });
        } else {
          const url = new URL(API_URL);
          Object.keys(params).forEach(key => url.searchParams.append(key, params[key]));
          response = await fetch(url.toString());
        }
        return await response.json();
      } catch (error) {
        return { success: false, message: 'Network error: ' + error.message };
      }
    }

    document.addEventListener('DOMContentLoaded', function() {
      const saved = sessionStorage.getItem('punchbook_employee');
      if (saved) {
        currentEmployee = JSON.parse(saved);
        showApp();
      }
      switchLoginMode('face');
      document.getElementById('loginForm').addEventListener('submit', handleLogin);
      document.getElementById('passwordForm').addEventListener('submit', handlePasswordChange);
      document.querySelectorAll('.tab-btn').forEach(btn => {
        btn.addEventListener('click', function() { switchTab(this.dataset.tab); });
      });
    });

    function switchTab(tab) {
      if (tab !== 'settings') { stopSettingsFaceCamera(); }

      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      document.querySelector(`[data-tab="${tab}"]`).classList.add('active');
      document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
      document.getElementById(tab + 'Tab').classList.add('active');
      
      if (tab === 'attendance') loadAttendance();
      if (tab === 'holiday') loadHolidays(); // NEW HOLIDAY LOAD
    }

    // ==============================================================
    // SETTINGS LIVE FACE CAPTURE
    // ==============================================================
    async function startSettingsFaceCamera() {
      const btn = document.getElementById('btnStartSettingsCam');
      btn.disabled = true;
      btn.innerHTML = '<div class="spinner" style="width:16px;height:16px;border-width:2px;display:inline-block;vertical-align:middle;margin-right:8px;border-top-color:var(--primary);"></div> Loading...';
      
      const statusEl = document.getElementById('settingsFaceStatus');
      statusEl.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Loading AI Models...';
      statusEl.className = 'face-status detecting';

      settingsFaceDescriptor = null;
      settingsPhotoBase64 = null;
      document.getElementById('settingsCapturedPhoto').style.display = 'none';

      try {
        await Promise.all([
          faceapi.nets.tinyFaceDetector.loadFromUri(MODEL_URL),
          faceapi.nets.faceLandmark68Net.loadFromUri(MODEL_URL),
          faceapi.nets.faceRecognitionNet.loadFromUri(MODEL_URL)
        ]);

        settingsStream = await navigator.mediaDevices.getUserMedia({ video: { width: 400, height: 300, facingMode: 'user' }, audio: false });
        const video = document.getElementById('settingsFaceVideo');
        video.srcObject = settingsStream;
        
        document.getElementById('settingsVideoContainer').style.display = 'block';
        document.getElementById('settingsCameraPlaceholder').style.display = 'none';
        
        btn.style.display = 'none';
        document.getElementById('btnCaptureSettingsCam').style.display = 'block';
        document.getElementById('btnCancelSettingsCam').style.display = 'block';
        document.getElementById('btnSaveSettingsFace').style.display = 'none';
        
        video.onloadedmetadata = () => { detectSettingsFace(); };
      } catch (err) {
        statusEl.innerHTML = '<i class="fas fa-exclamation-triangle"></i> Camera access denied';
        statusEl.className = 'face-status error';
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-video"></i> Start Camera';
      }
    }

    async function detectSettingsFace() {
      const video = document.getElementById('settingsFaceVideo');
      const canvas = document.getElementById('settingsFaceCanvas');
      const ctx = canvas.getContext('2d');
      canvas.width = video.videoWidth;
      canvas.height = video.videoHeight;
      const statusEl = document.getElementById('settingsFaceStatus');
      const captureBtn = document.getElementById('btnCaptureSettingsCam');

      settingsDetectionInterval = setInterval(async () => {
        const detections = await faceapi.detectSingleFace(video, new faceapi.TinyFaceDetectorOptions()).withFaceLandmarks().withFaceDescriptor();
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        
        if (detections) {
          const box = detections.detection.box;
          ctx.strokeStyle = '#10B981'; ctx.lineWidth = 3;
          ctx.strokeRect(box.x, box.y, box.width, box.height);
          statusEl.innerHTML = '<i class="fas fa-check-circle"></i> Face detected! Click Capture';
          statusEl.className = 'face-status detected';
          captureBtn.disabled = false;
        } else {
          statusEl.innerHTML = '<i class="fas fa-search"></i> Looking for face...';
          statusEl.className = 'face-status detecting';
          captureBtn.disabled = true;
        }
      }, 200);
    }

    async function captureSettingsFace() {
      const video = document.getElementById('settingsFaceVideo');
      const statusEl = document.getElementById('settingsFaceStatus');
      
      const detection = await faceapi.detectSingleFace(video, new faceapi.TinyFaceDetectorOptions()).withFaceLandmarks().withFaceDescriptor();
      
      if (detection) {
        settingsFaceDescriptor = Array.from(detection.descriptor);
        
        const tempCanvas = document.createElement('canvas');
        tempCanvas.width = video.videoWidth;
        tempCanvas.height = video.videoHeight;
        tempCanvas.getContext('2d').drawImage(video, 0, 0);
        settingsPhotoBase64 = tempCanvas.toDataURL('image/jpeg', 0.85);
        
        document.getElementById('settingsCapturedPhoto').src = settingsPhotoBase64;
        document.getElementById('settingsCapturedPhoto').style.display = 'block';
        document.getElementById('settingsVideoContainer').style.display = 'none';
        
        document.getElementById('btnCaptureSettingsCam').style.display = 'none';
        document.getElementById('btnSaveSettingsFace').style.display = 'block';
        document.getElementById('btnSaveSettingsFace').disabled = false;
        
        if (settingsDetectionInterval) clearInterval(settingsDetectionInterval);
        statusEl.innerHTML = '<i class="fas fa-check"></i> Face captured! Now click Save.';
        statusEl.className = 'face-status detected';
      } else {
        showToast('No face detected. Try again.', 'error');
      }
    }

    async function saveSettingsFaceData() {
      if (!settingsFaceDescriptor || !settingsPhotoBase64) return;
      
      const btn = document.getElementById('btnSaveSettingsFace');
      btn.disabled = true;
      btn.innerHTML = '<div class="spinner" style="width:16px;height:16px;border-width:2px;display:inline-block;vertical-align:middle;margin-right:8px;border-top-color:white;"></div> Saving...';

      try {
        const result = await apiCall({
          action: 'saveFaceData',
          empId: currentEmployee.empId,
          empName: currentEmployee.name,
          faceDescriptor: JSON.stringify(settingsFaceDescriptor), 
          photoBase64: settingsPhotoBase64
        });

        if (result.success) {
          showToast('Face Registration Successful!', 'success');
          stopSettingsFaceCamera();
          faceDataLoaded = false; 
          
          document.getElementById('headerAvatar').src = settingsPhotoBase64;
          document.getElementById('profileAvatar').src = settingsPhotoBase64;
        } else {
          showToast('Failed: ' + result.message, 'error');
        }
      } catch (error) {
        showToast('Network error while saving.', 'error');
      } finally {
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-save"></i> Save Face Data';
      }
    }

    function stopSettingsFaceCamera() {
      if (settingsDetectionInterval) { clearInterval(settingsDetectionInterval); settingsDetectionInterval = null; }
      if (settingsStream) { settingsStream.getTracks().forEach(t => t.stop()); settingsStream = null; }
      
      document.getElementById('settingsVideoContainer').style.display = 'none';
      document.getElementById('settingsCameraPlaceholder').style.display = 'flex';
      
      const statusEl = document.getElementById('settingsFaceStatus');
      statusEl.innerHTML = 'Ready to scan. Click "Start Camera".';
      statusEl.className = 'face-status';
      
      const btnStart = document.getElementById('btnStartSettingsCam');
      btnStart.style.display = 'block';
      btnStart.disabled = false;
      btnStart.innerHTML = '<i class="fas fa-video"></i> Start Camera';
      
      document.getElementById('btnCaptureSettingsCam').style.display = 'none';
      document.getElementById('btnSaveSettingsFace').style.display = 'none';
      document.getElementById('btnCancelSettingsCam').style.display = 'none';
    }


    /* =========================================================
       LOGIN AND FACE AUTH LOGIC 
       ========================================================= */

    function switchLoginMode(mode) {
      document.getElementById('faceTabBtn').classList.toggle('active', mode === 'face');
      document.getElementById('passTabBtn').classList.toggle('active', mode === 'password');
      document.getElementById('faceLoginSection').style.display = mode === 'face' ? 'block' : 'none';
      document.getElementById('passwordLoginSection').style.display = mode === 'password' ? 'block' : 'none';
      if (mode !== 'face') cancelFaceAuth();
    }

    async function startFaceAuth() {
      const startBtn = document.getElementById('startFaceBtn');
      startBtn.disabled = true;
      startBtn.innerHTML = '<div class="spinner" style="width:18px;height:18px;border-width:2px;"></div> Please wait...';
      document.getElementById('modelLoadingBar').style.display = 'flex';

      if (!faceApiLoaded) {
        setModelProgress(10, 'Loading AI Models...');
        const loaded = await loadFaceApiModels();
        if (!loaded) {
          startBtn.disabled = false;
          startBtn.innerHTML = '<i class="fas fa-camera"></i> Start Face Scan';
          document.getElementById('modelLoadingBar').style.display = 'none';
          return;
        }
      }

      if (!faceDataLoaded) {
        setModelProgress(85, 'Employees ka face data load ho raha hai...');
        await loadAllFaceDescriptors();
      }

      setModelProgress(100, 'Ready!');
      setTimeout(() => { document.getElementById('modelLoadingBar').style.display = 'none'; }, 500);

      document.getElementById('faceStep1').style.display = 'none';
      document.getElementById('faceStep2').style.display = 'block';
      await startLoginCamera();
    }

    async function loadFaceApiModels() {
      try {
        setModelProgress(20, 'Loading Face Detector...');
        await faceapi.nets.tinyFaceDetector.loadFromUri(MODEL_URL);
        setModelProgress(55, 'Loading Landmark Model...');
        await faceapi.nets.faceLandmark68Net.loadFromUri(MODEL_URL); 
        setModelProgress(80, 'Loading Recognition Model...');
        await faceapi.nets.faceRecognitionNet.loadFromUri(MODEL_URL);
        faceApiLoaded = true;
        return true;
      } catch (err) {
        showToast('AI Models load nahi hue. Internet check karein.', 'error');
        return false;
      }
    }

    async function loadAllFaceDescriptors() {
      allFaceDescriptors = [];
      try {
        const result = await apiCall({ action: 'getAllFaceData' });
        if (!result.success || !result.faces || result.faces.length === 0) return;
        
        const promises = result.faces.map(async (face) => {
          let descriptor = null;
          if (face.faceDescriptor && face.faceDescriptor.length === 128) {
            descriptor = new Float32Array(face.faceDescriptor);
          } else if (face.photoURL) {
            descriptor = await getDescriptorFromURL(face.photoURL);
          }
          
          if (descriptor) {
            allFaceDescriptors.push({ empId: face.empId, name: face.name, photoURL: face.photoURL, descriptor: descriptor });
          }
        });
        await Promise.all(promises);
        faceDataLoaded = allFaceDescriptors.length > 0;
      } catch (e) {}
    }

    function setModelProgress(pct, text) {
      document.getElementById('modelBarFill').style.width = pct + '%';
      document.getElementById('modelLoadingText').textContent = text;
    }

    async function startLoginCamera() {
      try {
        loginStream = await navigator.mediaDevices.getUserMedia({ video: { width: { ideal: 640 }, height: { ideal: 480 }, facingMode: 'user' }, audio: false });
        const video = document.getElementById('faceVideo');
        video.srcObject = loginStream;
        await new Promise(res => { video.onloadedmetadata = res; });
        video.play();
        document.getElementById('cameraPlaceholder').style.display = 'none';
        video.style.display = 'block';
        const overlay = document.getElementById('faceOverlay');
        overlay.style.display = 'block';
        overlay.width = video.videoWidth;
        overlay.height = video.videoHeight;
        startLoginLiveDetection();
      } catch (err) {
        setFaceStatus('Camera access denied.', 'error');
      }
    }

    function startLoginLiveDetection() {
      const video = document.getElementById('faceVideo');
      const overlay = document.getElementById('faceOverlay');
      const ctx = overlay.getContext('2d');
      document.getElementById('scanLine').classList.add('active');

      loginDetectionInterval = setInterval(async () => {
        if (loginCaptureInProgress) return;
        ctx.clearRect(0, 0, overlay.width, overlay.height);
        try {
          const detection = await faceapi.detectSingleFace(video, new faceapi.TinyFaceDetectorOptions({ inputSize: 224, scoreThreshold: 0.5 }));
          if (detection) {
            loginFaceDetected = true;
            const { x, y, width, height } = detection.box;
            ctx.strokeStyle = '#10B981'; ctx.lineWidth = 2; ctx.strokeRect(x, y, width, height);
            document.getElementById('scanRing').className = 'scan-ring';
            document.getElementById('scanRing').style.borderColor = 'rgba(16,185,129,0.8)';
            document.getElementById('captureBtn').disabled = false;
            setFaceStatus('✓ Face detect ho gaya! "Verify Now" dabayein.', 'success');
          } else {
            loginFaceDetected = false;
            document.getElementById('scanRing').className = 'scan-ring';
            document.getElementById('scanRing').style.borderColor = 'rgba(59,130,246,0.6)';
            document.getElementById('captureBtn').disabled = true;
            setFaceStatus('Camera ko seedha face ke saamne rakhein...', '');
          }
        } catch (e) { }
      }, 400);
    }

    async function captureFaceLogin() {
      if (!loginFaceDetected || loginCaptureInProgress) return;
      loginCaptureInProgress = true;
      const video = document.getElementById('faceVideo');
      const ring = document.getElementById('scanRing');

      ring.className = 'scan-ring scanning';
      setFaceStatus('Face scan ho raha hai...', 'warning');
      document.getElementById('captureBtn').disabled = true;
      document.getElementById('empRevealCard').classList.remove('show');

      try {
        const liveDetection = await faceapi.detectSingleFace(video, new faceapi.TinyFaceDetectorOptions({ inputSize: 224, scoreThreshold: 0.5 })).withFaceLandmarks().withFaceDescriptor();

        if (!liveDetection) {
          ring.className = 'scan-ring error';
          setFaceStatus('Face clearly capture nahi hua. Dobara try karein.', 'error');
          resetLoginCaptureState(2000); return;
        }

        if (allFaceDescriptors.length === 0) {
          ring.className = 'scan-ring error';
          setFaceStatus('Face data nahi mila. Admin se contact karein.', 'error');
          resetLoginCaptureState(2000); return;
        }

        let bestMatch = null; let bestDistance = Infinity; const THRESHOLD = 0.55;

        for (const emp of allFaceDescriptors) {
          const distance = faceapi.euclideanDistance(liveDetection.descriptor, emp.descriptor);
          if (distance < bestDistance) { bestDistance = distance; bestMatch = emp; }
        }

        if (bestMatch && bestDistance <= THRESHOLD) {
          ring.className = 'scan-ring success';
          clearInterval(loginDetectionInterval);
          document.getElementById('scanLine').classList.remove('active');

          const avatarURL = bestMatch.photoURL || `https://ui-avatars.com/api/?name=${encodeURIComponent(bestMatch.name)}&size=200`;
          document.getElementById('empRevealAvatar').src = avatarURL;
          document.getElementById('empRevealName').textContent = bestMatch.name;
          document.getElementById('empRevealId').textContent = '🪪 ' + bestMatch.empId;
          document.getElementById('empRevealCard').classList.add('show');
          setFaceStatus('✓ Face verified! Logging in...', 'success');

          const profileResult = await apiCall({ action: 'getEmployeeProfile', empId: bestMatch.empId });
          if (profileResult.success) {
            const emp = profileResult.employee;
            if (emp.status !== 'Active') {
              ring.className = 'scan-ring error'; setFaceStatus('Account inactive hai.', 'error');
              document.getElementById('empRevealCard').classList.remove('show'); loginCaptureInProgress = false; return;
            }
            currentEmployee = emp;
            sessionStorage.setItem('punchbook_employee', JSON.stringify(currentEmployee));
            setTimeout(() => { stopLoginCamera(); showApp(); showToast('Welcome back, ' + currentEmployee.name + '! 👋', 'success'); }, 1400);
          }
        } else {
          ring.className = 'scan-ring error';
          setFaceStatus(`Face kisi se match nahi hua. Dobara try karein.`, 'error');
          resetLoginCaptureState(2200);
        }
      } catch (err) {
        ring.className = 'scan-ring error'; setFaceStatus('Error: ' + err.message, 'error'); resetLoginCaptureState(2000);
      }
    }

    function resetLoginCaptureState(delay) {
      setTimeout(() => {
        loginCaptureInProgress = false; document.getElementById('captureBtn').disabled = false;
        document.getElementById('scanRing').className = 'scan-ring'; document.getElementById('scanRing').style.borderColor = 'rgba(59,130,246,0.6)';
        setFaceStatus('Camera ko seedha face ke saamne rakhein...', '');
        if (!loginDetectionInterval || loginDetectionInterval._destroyed) startLoginLiveDetection();
      }, delay);
    }

    async function getDescriptorFromURL(url) {
      return new Promise(async (resolve) => {
        try {
          const img = new Image(); img.crossOrigin = 'anonymous';
          img.onload = async () => { try { const detection = await faceapi.detectSingleFace(img, new faceapi.TinyFaceDetectorOptions({ inputSize: 224, scoreThreshold: 0.3 })).withFaceLandmarks().withFaceDescriptor(); resolve(detection ? detection.descriptor : null); } catch (e) { resolve(null); } };
          img.onerror = () => resolve(null);
          let loadUrl = url; if (url.includes('drive.google.com')) { const match = url.match(/[-\w]{25,}/); if (match) loadUrl = `https://drive.google.com/uc?export=view&id=${match[0]}`; }
          img.src = loadUrl; setTimeout(() => resolve(null), 10000);
        } catch (e) { resolve(null); }
      });
    }

    function setFaceStatus(msg, type) {
      const el = document.getElementById('faceStatusMsg');
      el.textContent = msg; el.className = 'face-status-msg ' + (type || '');
    }

    function stopLoginCamera() {
      if (loginDetectionInterval) clearInterval(loginDetectionInterval);
      loginDetectionInterval = null;
      if (loginStream) { loginStream.getTracks().forEach(t => t.stop()); loginStream = null; }
    }

    function cancelFaceAuth() {
      stopLoginCamera(); loginCaptureInProgress = false; loginFaceDetected = false;
      document.getElementById('faceStep1').style.display = 'block'; document.getElementById('faceStep2').style.display = 'none';
      document.getElementById('empRevealCard').classList.remove('show');
      const startBtn = document.getElementById('startFaceBtn'); startBtn.disabled = false; startBtn.innerHTML = '<i class="fas fa-camera"></i> Start Face Scan';
      const video = document.getElementById('faceVideo'); video.srcObject = null; video.style.display = 'none';
      document.getElementById('faceOverlay').style.display = 'none'; document.getElementById('cameraPlaceholder').style.display = 'flex';
      document.getElementById('scanLine').classList.remove('active'); document.getElementById('scanRing').className = 'scan-ring'; document.getElementById('scanRing').style.borderColor = '';
      document.getElementById('captureBtn').disabled = true; setFaceStatus('Camera ko face ke saamne rakhein...', '');
    }

    async function handleLogin(e) {
      e.preventDefault();
      const empId = document.getElementById('loginEmpId').value.trim();
      const password = document.getElementById('loginPassword').value;
      showToast('Logging in...', '');
      const result = await apiCall({ action: 'employeeLogin', empId, password });
      if (result.success) { currentEmployee = result.employee; sessionStorage.setItem('punchbook_employee', JSON.stringify(currentEmployee)); showApp(); showToast('Welcome back, ' + currentEmployee.name + '!', 'success'); } 
      else { showToast(result.message, 'error'); }
    }

    function logout() {
      stopLoginCamera(); stopSettingsFaceCamera();
      sessionStorage.removeItem('punchbook_employee'); currentEmployee = null;
      document.getElementById('loginPage').style.display = 'flex'; document.getElementById('appContainer').style.display = 'none';
      cancelFaceAuth(); switchLoginMode('face');
    }

    function showApp() {
      document.getElementById('loginPage').style.display = 'none'; document.getElementById('appContainer').style.display = 'block';
      document.getElementById('headerName').textContent = currentEmployee.name;
      loadTodayStatus(); loadProfile(); loadMonthSelector(); loadRecentActivity();
    }

    async function loadTodayStatus() {
      document.getElementById('todayDate').textContent = new Date().toLocaleDateString('en-IN', { weekday: 'long', day: '2-digit', month: 'long', year: 'numeric' });
      const result = await apiCall({ action: 'getTodayStatus', empId: currentEmployee.empId });
      if (result.success) {
        document.getElementById('todayPunchIn').textContent = result.punchIn || '--:--'; document.getElementById('todayPunchOut').textContent = result.punchOut || '--:--'; document.getElementById('todayHours').textContent = result.workHours ? result.workHours + ' hrs' : '--';
        const badge = document.getElementById('todayBadge'); badge.textContent = result.status; badge.className = 'today-badge';
        if (result.status === 'Present') badge.classList.add('success'); else if (result.status === 'Late') badge.classList.add('warning');
      }
      const now = new Date(); const summaryResult = await apiCall({ action: 'getAttendanceSummary', empId: currentEmployee.empId, month: now.getMonth() + 1, year: now.getFullYear() });
      if (summaryResult.success) {
        document.getElementById('quickPresent').textContent = summaryResult.summary.presentDays; document.getElementById('quickAbsent').textContent = summaryResult.summary.absentDays;
        document.getElementById('quickLate').textContent = summaryResult.summary.lateDays; document.getElementById('quickPercent').textContent = summaryResult.summary.attendancePercent + '%';
        document.getElementById('quickWeekOff').textContent = summaryResult.summary.weekOffs || '0'; document.getElementById('quickHoliday').textContent = summaryResult.summary.holidays || '0';
      }
    }

    async function loadProfile() {
      const result = await apiCall({ action: 'getEmployeeProfile', empId: currentEmployee.empId });
      if (result.success) {
        const emp = result.employee;
        const photoURL = result.photoURL || 'https://ui-avatars.com/api/?name=' + encodeURIComponent(emp.name) + '&size=200';
        document.getElementById('headerAvatar').src = photoURL; document.getElementById('profileAvatar').src = photoURL;
        document.getElementById('profileName').textContent = emp.name; document.getElementById('profileEmpId').textContent = emp.empId;
        document.getElementById('profileDept').textContent = emp.department; document.getElementById('profileEmail').textContent = emp.email;
        document.getElementById('profilePhone').textContent = emp.phone || 'Not set'; document.getElementById('profileDesignation').textContent = emp.designation;
        document.getElementById('profileJoinDate').textContent = formatDate(emp.joinDate); document.getElementById('profileWeekOff').textContent = emp.weekOff || 'Sunday';
        document.getElementById('profileStatus').textContent = emp.status;
      }
    }

    async function loadMonthSelector() {
      const result = await apiCall({ action: 'getAvailableMonths' });
      if (result.success) { const select = document.getElementById('monthSelector'); select.innerHTML = result.months.map(m => `<option value="${m.value}">${m.label}</option>`).join(''); loadAttendance(); }
    }

    async function loadAttendance() {
      const monthValue = document.getElementById('monthSelector').value; if (!monthValue) return;
      const [month, year] = monthValue.split('-'); document.getElementById('attendanceTable').innerHTML = '<tr><td colspan="5" class="loading"><div class="spinner"></div></td></tr>';
      const result = await apiCall({ action: 'getAttendanceSummary', empId: currentEmployee.empId, month: parseInt(month), year: parseInt(year) });
      if (result.success) {
        document.getElementById('monthPresent').textContent = result.summary.presentDays; document.getElementById('monthAbsent').textContent = result.summary.absentDays; document.getElementById('monthLate').textContent = result.summary.lateDays;
        document.getElementById('monthHours').textContent = result.summary.totalHours; document.getElementById('monthWeekOff').textContent = result.summary.weekOffs || '0'; document.getElementById('monthHoliday').textContent = result.summary.holidays || '0';
        renderAttendanceTable(result.records, 'attendanceTable');
      }
    }

    async function loadRecentActivity() {
      const result = await apiCall({ action: 'getRecentActivity', empId: currentEmployee.empId, limit: 5 });
      if (result.success) renderAttendanceTable(result.records, 'recentActivityTable');
    }

    // NEW FUNCTION TO LOAD HOLIDAYS
    async function loadHolidays() {
      const tbody = document.getElementById('holidayTable');
      tbody.innerHTML = '<tr><td colspan="3" class="loading"><div class="spinner"></div></td></tr>';
      
      const result = await apiCall({ action: 'getHolidaysList' });
      
      if (result.success) {
        if (result.holidays.length === 0) {
          tbody.innerHTML = '<tr><td colspan="3" class="empty-state"><i class="fas fa-umbrella-beach"></i><p>No holidays found</p></td></tr>';
          return;
        }
        tbody.innerHTML = result.holidays.map(h => {
          return `<tr>
            <td><strong>${h.dateStr}</strong></td>
            <td>${h.dayName}</td>
            <td><span class="badge badge-purple">${h.name}</span></td>
          </tr>`;
        }).join('');
      } else {
        tbody.innerHTML = `<tr><td colspan="3" class="empty-state"><p>Error loading holidays.</p></td></tr>`;
      }
    }

    function renderAttendanceTable(records, tableId) {
      const tbody = document.getElementById(tableId);
      if (records.length === 0) { tbody.innerHTML = '<tr><td colspan="5" class="empty-state"><i class="fas fa-calendar-times"></i><p>No records found</p></td></tr>'; return; }
      tbody.innerHTML = records.map(r => `<tr><td>${formatDate(r.date)}</td><td>${r.punchIn || '-'}</td><td>${r.punchOut || '-'}</td><td>${r.workHours ? r.workHours + ' hrs' : '-'}</td><td><span class="badge badge-${r.status === 'Present' ? 'success' : r.status === 'Late' ? 'warning' : 'danger'}">${r.status}</span></td></tr>`).join('');
    }

    async function handlePasswordChange(e) {
      e.preventDefault();
      const currentPassword = document.getElementById('currentPassword').value; const newPassword = document.getElementById('newPassword').value; const confirmPassword = document.getElementById('confirmPassword').value;
      if (newPassword !== confirmPassword) { showToast('New passwords do not match', 'error'); return; }
      if (newPassword.length < 6) { showToast('Password must be at least 6 characters', 'error'); return; }
      const result = await apiCall({ action: 'changePassword', empId: currentEmployee.empId, currentPassword, newPassword });
      if (result.success) { showToast(result.message, 'success'); document.getElementById('passwordForm').reset(); } else showToast(result.message, 'error');
    }

    function showToast(message, type) { const toast = document.getElementById('toast'); toast.textContent = message; toast.className = 'toast show ' + type; setTimeout(() => toast.classList.remove('show'), 3000); }
    function formatDate(dateStr) { if (!dateStr) return '-'; return new Date(dateStr).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' }); }
  </script>
</body>
